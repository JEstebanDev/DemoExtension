{
  "manifest_version": 3,
  "name": "Excel Stepper Form Filler",
  "version": "1.0.0",
  "description": "Extensión para rellenar automáticamente formularios con steppers desde archivos Excel",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/shared/messages.js",
        "src/shared/logger.js",
        "src/shared/utils/text.js",
        "src/shared/utils/time.js",
        "src/content/dom/waiters.js",
        "src/content/dom/selectors.js",
        "src/content/dom/actions.js",
        "src/content/steps/step1BasicInfo.js",
        "src/content/steps/step2Experience.js",
        "src/content/steps/step3Skills.js",
        "src/content/steps/step4Education.js",
        "src/content/orchestrator/navigation.js",
        "src/content/orchestrator/fillFormFlow.js",
        "src/content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background/index.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "example_data.xls",
        "example_data.json",
        "config/mapping/example_data.json",
        "assets/GFT.webp",
        "assets/icon16.png",
        "assets/icon32.png",
        "assets/icon48.png",
        "assets/icon128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}

